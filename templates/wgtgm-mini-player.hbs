<section class="wgtngm-mini-player">
    <div class="wgtngm-drawer-container {{#if isDrawerOpen}}open{{/if}}">
        <i class="fas fa-caret-down wgtngm-drawer-handle" data-action="open-playlists"></i>
<div class="wgtngm-drawer-content">
            {{#if tagMode}}
                <div class="tag-cloud">
                    {{#if showTTRPGToggle}}
                    <button type="button" class="tag-toggle wgtngm-tag-chip {{#if ttrpgEnabled}}enabled{{/if}}" data-action="toggle-ttrpg-source"
                            title="{{ttrpgSourceToggleTitle}}">
                        TTRPG
                    </button>
                    {{/if}}

                    {{#each tags}}
                    <button type="button" class="tag-toggle wgtngm-tag-chip {{this.stateClass}}" data-action="toggle-tag-select" data-tag="{{this.name}}"
                            title="{{../tagToggleTitle}}">
                        {{this.name}}
                    </button>
                    {{/each}}
                </div>
            
                <div class="form-group">
                    <label for="track-select">{{resultsLabel}}</label>
                    <select name="track-select" id="track-select">
                        {{#each tracks}}
                        <option value="{{this.id}}" {{#if this.isSelected}}selected{{/if}}>
                            {{#if this.playing}}&#9658;{{/if}} {{this.name}}
                        </option>
                        {{else}}
                        <option value="">{{noMatchesText}}</option>
                        {{/each}}
                    </select>
                </div>
            {{else}}
                <div class="form-group">
                    <label for="playlist-select">{{playlistLabel}}</label>
                    <select name="playlist-select" id="playlist-select">
                        {{#each playlists}}
                        <option value="{{this.id}}" {{#if this.isSelected}}selected{{/if}}>
                            {{#if this.playing}}&#9658;{{/if}} {{this.name}}
                        </option>
                        {{/each}}
                    </select>
                </div>
                {{!-- Standard Track Dropdown --}}
                <div class="form-group">
                    <label for="track-select">{{trackLabel}}</label>
                    <select name="track-select" id="track-select">
                        {{#each tracks}}
                        <option value="{{this.id}}" {{#if this.isSelected}}selected{{/if}}>
                            {{#if this.playing}}&#9658;{{/if}} {{this.name}} {{#if this.isMuted}} &#128263;{{/if}}{{#if this.repeat}} &#128257;{{/if}}{{#if this.isFavorite}} &#11088;{{/if}}
                        </option>
                        {{else}}
                        <option value="">{{selectTrackText}}</option>
                        {{/each}}
                    </select>
                </div>
            {{/if}}
        </div>
    </div>

    <div class="wgtngm-player-body">
        <div class="wgtngm-main-bar">
            <div class="wgtngm-now-playing">
                <i class="{{#if isFavorite}}fas fa-star{{else}}far fa-star{{/if}} wgtngm-favorite " data-action="wgtngm-favorite" title="{{favoriteTitle}}"> </i>
                <span class="wgtngm-track-name">{{nowPlaying}}</span>
            </div>
            <div class="wgtngm-time-display">
                <span class="wgtngm-current-time">00:00</span> / <span class="wgtngm-duration-time">00:00</span>
                <i class="fas fa-shuffle wgtngm-fade {{#if isFade}}fade{{/if}}" data-action="fadeSounds" title="{{crossfadeTitle}}"></i>
                <i class="fas fa-repeat wgtngm-loop {{#if isLooping}}open{{/if}}" data-action="wgtngm-loop" title="{{loopTitle}}"></i>
            </div>
        </div>
        <div class="wgtngm-control-wrapper">
            <div class="wgtngm-player-controls">
                <button class="wgtngm-previous-track" data-action="previous-track" title="{{previousTrackTitle}}"><i class="fas fa-backward"></i></button>
                <button data-action="toggle-play-pause" title="{{playPauseTitle}}"><i class="fas {{#if isPlaying}}fa-pause{{else}}fa-play{{/if}}"></i></button>
                <button class="wgtngm-stop-track" data-action="stop-track" title="{{stopTitle}}"><i class="fas fa-stop"></i></button>
                <button data-action="next-track" title="{{nextTrackTitle}}"><i class="fas fa-forward"></i></button>
            </div>
            <div class="wgtngm-playback-bar">
                <div class="wgtngm-volume-control">
                    <button type="button" class="wgtngm-mute-button" data-action="toggle-mute" title="{{muteTitle}}">
                        <i class="fas {{#if isMuted}}fa-volume-xmark{{else}}fa-volume-high{{/if}}"></i>
                    </button>
                    <input type="range" name="volume" min="0" max="1" step="0.05" value="{{volume}}">
                </div>
            </div>
        </div>
        <div class="wgtngm-track-info">
            <div class="wgtngm-next-up">
                <strong>{{nextLabel}}</strong>
                <span class="wgtngm-next-track-name">{{nextUp}}</span>
            </div>
        </div>
    </div>
</section>
